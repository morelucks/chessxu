{
  "name": "@morelucks/chessxu-sdk",
  "version": "1.1.0",
  "description": "SDK for interacting with Chessxu Clarity contracts on Stacks Mainnet",
  "main": "./dist/cjs/index.js",
  "module": "./dist/esm/index.js",
  "types": "./dist/cjs/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/esm/index.d.ts",
        "default": "./dist/esm/index.js"
      },
      "require": {
        "types": "./dist/cjs/index.d.ts",
        "default": "./dist/cjs/index.js"
      }
    }
  },
  "scripts": {
    "build:cjs": "tsc -p tsconfig.cjs.json",
    "build:esm": "tsc -p tsconfig.esm.json && node scripts/add-esm-package.js",
    "build": "npm run build:cjs && npm run build:esm",
    "test": "tsc -p tsconfig.test.json && node --test dist-test/tests/*.test.js && jest",
    "test:coverage": "tsc -p tsconfig.test.json && c8 --reporter=lcov --reporter=text --reporter=json-summary --include='dist-test/src/**' node --test dist-test/tests/*.test.js",
    "coverage:check": "c8 check-coverage --lines 90 --functions 90 --branches 80 --statements 90",
    "typecheck": "tsc --noEmit",
    "verify": "node scripts/verify-build.js",
    "prepublishOnly": "npm run build && npm run verify"
  },
  "files": [
    "dist"
  ],
  "keywords": [
    "stacks",
    "clarity",
    "chess",
    "sip-010",
    "esm",
    "cjs"
  ],
  "author": "morelucks",
  "license": "MIT",
  "dependencies": {
    "@stacks/network": "^7.0.0",
    "@stacks/transactions": "^7.0.0"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "^25.9.1",
    "c8": "^10.1.3",
    "jest": "^29.7.0",
    "ts-jest": "^29.4.11",
    "typescript": "^5.0.0"
  }
}
